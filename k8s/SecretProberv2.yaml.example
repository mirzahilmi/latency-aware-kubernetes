---
apiVersion: v1
kind: Secret
metadata:
  name: proberv2-secrets
  namespace: riset
stringData:
  config: |-
    {
        "shutdownTimeout": 10,
        "kubernetes": {
            "namespace": "riset",
            "service": "example-svc",
            "targetPort": 8080
        },
        "prometheus": {
            "url": "http://example.com:9090"
        },
        "nftables": {
            "table": "mirzaganteng",
            "chainPrerouting": "prerouting",
            "chainServices": "services",
            "setAllowedNodeIps": "nodeport-ips",
            "mapServiceChainByNodeport": "service-verdict-by-nodeport",
            "prefixServiceEndpoint": "yowes-ikilo",
            "probabilityCap": 100000
        },
        "probe": {
            "latencyInterval": 10,
            "cpuInterval": 10,
            "nftUpdateInterval": 10
        },
        "alpha": {
            "ewmaLatency": 0.2,
            "ewmaCpu": 0.2
        }
    }
